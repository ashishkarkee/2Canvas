{
  "manifest_version": 3,
  "name": "Canvas Due Today",
  "version": "1.0.0",
  "description": "See all assignments due today across your Canvas accounts at multiple community colleges.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.instructure.com/*",
    "https://*.canvas.net/*",
    "https://*.canvaslms.com/*",
    "https://*.edu/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}